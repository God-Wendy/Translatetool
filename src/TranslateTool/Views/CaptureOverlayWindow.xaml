<?xml version="1.0" encoding="UTF-8" ?>
<Window
    x:Class="TranslateTool.Views.CaptureOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid
        x:Name="RootGrid"
        PointerPressed="OnOverlayPressed"
        PointerMoved="OnOverlayMoved"
        PointerReleased="OnOverlayReleased"
        KeyDown="OnWindowKeyDown">
        <Image x:Name="ScreenPreview" Stretch="Fill" />

        <Canvas>
            <Rectangle
                x:Name="SelectionRect"
                Fill="#2200AEEF"
                Stroke="#FF00AEEF"
                StrokeThickness="2"
                Visibility="Collapsed" />

            <Border
                x:Name="PixelBadge"
                Background="#CC111111"
                CornerRadius="6"
                Padding="8,4"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="PixelBadgeText"
                    Foreground="White"
                    FontSize="13"
                    Text="0 x 0" />
            </Border>
        </Canvas>

        <StackPanel
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,12,12,0">
            <Button
                x:Name="ConfirmButton"
                Content="确认截图"
                Click="OnConfirmClicked"
                IsEnabled="False" />
            <Button
                Content="取消"
                Margin="8,0,0,0"
                Click="OnCancelClicked" />
        </StackPanel>
    </Grid>
</Window>
